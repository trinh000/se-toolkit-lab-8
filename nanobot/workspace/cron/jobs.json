{
  "version": 1,
  "jobs": [
    {
      "id": "health-check",
      "name": "Periodic Health Check",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "atMs": null,
        "everyMs": null,
        "expr": "*/15 * * * *",
        "tz": "UTC"
      },
      "payload": {
        "kind": "agent_turn",
        "message": "Perform a health check: 1) Check VictoriaLogs health using observability_logs_health tool, 2) Check for recent errors using observability_recent_errors tool, 3) Check backend health using lms_health tool. Post a summary report with your findings.",
        "deliver": true,
        "channel": "webchat",
        "to": "*"
      },
      "state": {
        "nextRunAtMs": 1775062800000,
        "lastRunAtMs": null,
        "lastStatus": null,
        "lastError": null,
        "runHistory": []
      },
      "createdAtMs": 0,
      "updatedAtMs": 0,
      "deleteAfterRun": false
    }
  ]
}